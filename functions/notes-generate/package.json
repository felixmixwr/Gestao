{
  "name": "notes-generate",
  "version": "1.0.0",
  "description": "Backend function para gerar notas fiscais em XLSX/PDF - Supabase Edge Function, Vercel Function ou Netlify",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node test.js",
