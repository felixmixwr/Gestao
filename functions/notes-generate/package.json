    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "supabase",
    "xlsx",
    "pdf",
    "invoices",
    "vercel",
    "netlify",
    "edge-function",
    "nodejs",
    "express"
  ],
