{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/notes/generate",
      "dest": "/index.js"
    },
    {
      "src": "/health",
      "dest": "/index.js"
    }
  ],
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_SERVICE_ROLE_KEY": "@supabase_service_role_key",
    "SUPABASE_BUCKET_INVOICES": "invoices"
  },
  "functions": {
    "index.js": {
      "maxDuration": 30
    }
  }
}
